{
  "name": "fuliao-system",
  "version": "0.1.0",
  "private": true,
  "description": "服装工厂辅料·布料·财务一体化管理系统",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "npx prisma db push --accept-data-loss && npx tsx prisma/seed.ts && next start -p ${PORT:-3000}",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "db:push": "prisma db push --accept-data-loss",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "jose": "^5.9.6",
    "next": "14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "prisma": "^5.22.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
